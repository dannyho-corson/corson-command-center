# Copy to .env.local (gitignored) and fill in your Anthropic API key.
# The Offer Bin component uses this to call Claude directly from the browser.
#
# ⚠ SECURITY NOTE — CRA bakes REACT_APP_* env vars into the public JS
# bundle served to every visitor. Only use this on a deployment that is
# not publicly accessible (Vercel password protection / private link).
# For a public-facing app, replace the direct Anthropic call in
# OfferBin.js with a serverless-function proxy that holds the key
# server-side.
REACT_APP_ANTHROPIC_API_KEY=sk-ant-...
